---
import Layout from '../layouts/Layout.astro';
import SimilarArticles from '../components/SimilarArticles.astro';
import PrevNextNav from '../components/PrevNextNav.astro';
import keywordsData from '../../keywords.json';

export const frontmatter = {
  title: "Foarfeca electrica pentru gard viu",
  excerpt: "Daca ai un gard viu sau arbusti ornamentali, o foarfeca electrica pentru gard viu este unealta de care ai nevoie pentru a mentine forma si sanatatea acestora cu efort minim. Aceste unelte elimina munca fizica greoaie asociata cu foarfecele manuale, permitandu-ti sa finalizezi treaba rapid si eficient, indiferent de lungimea sau grosimea crengilor.",
  image: "/images/articles/foarfeca-electrica-pentru-gard-viu.webp",
  category: "Gradinarit si Unelte",
  categorySlug: "gradinarit-unelte",
  date: "2026-03-11T07:52:54.983Z",
  modifiedDate: "2026-03-11T07:52:54.983Z",
  author: "Andrei Marinescu",
  authorRole: "Expert Gradinarit",
  authorBio: "Cu peste 10 ani de experienta in amenajarea gradinilor si alegerea echipamentelor potrivite, Andrei a testat sute de unelte si utilaje pentru gradinarit. Pasionat de agricultura urbana si gradini sustenabile."
};

const faq = [
  { question: "Cat costa o foarfeca electrica pentru gard viu?", answer: "Preturile variaza intre 150 lei pentru modelele entry-level cu fir si peste 700 lei pentru cele pe acumulator, cu baterii incluse si performante ridicate. Modelele de mijloc, cu un bun raport calitate-pret, se incadreaza in intervalul 300-500 lei." },
  { question: "Care este diferenta dintre o foarfeca electrica si una pe acumulator?", answer: "Foarfecele electrice cu fir ofera putere constanta si sunt, de obicei, mai ieftine, dar necesita acces la priza. Cele pe acumulator ofera libertate de miscare totala, fiind ideale pentru gradini mari, dar au o autonomie limitata de bateria reincarcabila." },
  { question: "Ce diametru maxim de creanga poate taia o foarfeca electrica?", answer: "Majoritatea modelelor electrice cu fir pot taia crengi de pana la 18-24mm. Unele modele, precum Black+Decker GT5500 cu functia 'Saw Blade', pot aborda crengi usor mai groase. Modelele cu acumulator au, de obicei, o capacitate de taiere similara sau usor inferioara." },
  { question: "Merita sa cumpar o foarfeca electrica cu lama lunga?", answer: "O lama lunga (50-55cm) este eficienta pentru garduri vii mari, permitand acoperirea rapida a suprafetelor. Totusi, poate fi mai greu de manevrat in spatii inguste sau pentru detalii fine. Pentru garduri mici, o lama mai scurta poate fi mai potrivita." },
  { question: "Ce inseamna puterea motorului (W) pentru o foarfeca electrica?", answer: "Puterea motorului indica forta unealtei. Un motor mai puternic (ex: 600W) va face fata mai usor crengilor groase si dense, asigurand o taiere mai rapida si fara efort. Modelele cu putere mai mica (ex: 450W) sunt potrivite pentru crengi subtiri si intretinere usoara." }
];

const toc = [
  { title: "Bosch UniversalHedgeCut 55", id: "bosch-universalhedgecut-55" },
  { title: "Makita UH5570", id: "makita-uh5570" },
  { title: "Einhell GC-EH 5550", id: "einhell-gc-eh-5550" },
  { title: "Black+Decker GT5500", id: "blackdecker-gt5500" },
  { title: "Worx WG204E", id: "worx-wg204e" },
  { title: "Gardena EasyCut 450/50", id: "gardena-easycut-45050" },
  { title: "Comparatie", id: "comparatie" },
  { title: "Cum alegi cea mai buna foarfeca electrica pentru gard viu?", id: "ghid" },
  { title: "Intrebari Frecvente", id: "faq" }
];

// Get all articles for similar articles component
const allArticles = keywordsData.completed.map(item => ({
  title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
  slug: item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, ''),
  excerpt: item.excerpt || '',
  image: `/images/articles/${item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}.webp`,
  category: item.category,
  categorySlug: item.categorySlug,
  date: item.date || new Date().toISOString()
}));
---

<Layout
