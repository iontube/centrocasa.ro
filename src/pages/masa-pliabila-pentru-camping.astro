  category: "Mobilier Gradina",
  categorySlug: "mobilier-gradina",
  date: "2026-03-12T08:09:10.178Z",
  modifiedDate: "2026-03-12T08:09:10.178Z",
  author: "Maria Ionescu",
  authorRole: "Designer Interior",
