        const atEnd = wrap.scrollLeft + wrap.clientWidth >= wrap.scrollWidth - 2;
        outer.classList.toggle('can-scroll', canScroll && !atEnd);
      }
      checkScroll();
      wrap.addEventListener('scroll', checkScroll, { passive: true });
