---
import Layout from '../layouts/Layout.astro';
import SimilarArticles from '../components/SimilarArticles.astro';
import keywordsData from '../../keywords.json';

export const frontmatter = {
  title: "Aer conditionat pentru apartament mic",
  excerpt: "Locuiesti intr-un apartament mai mic si vara te chinui cu caldura, iar iarna frigul isi face simtita prezenta? Alegerea unui aer conditionat potrivit poate face o diferenta uriasa in confortul tau zilnic. Nu e chiar asa complicat cum pare, hai sa vedem impreuna cum gasesti solutia ideala.",
  image: "/images/articles/aer-conditionat-pentru-apartament-mic.webp",
  category: "Electrocasnice Casa",
  categorySlug: "electrocasnice-casa",
  date: "2026-01-03T06:00:00.000Z",
  modifiedDate: "2026-01-26T06:00:00.000Z",
  author: "Cristian Popa",
  authorRole: "Specialist Electrocasnice",
  authorBio: "Cristian testeaza si recenzeaza electrocasnice de peste 6 ani, cu focus pe eficienta energetica si raportul calitate-pret. A analizat peste 500 de produse pentru case moderne."
};

const faq = [
  { question: "Ce inseamna BTU si de ce e important pentru un apartament mic?", answer: "BTU (British Thermal Unit) este unitatea de masura pentru puterea de racire a unui aparat de aer conditionat. Pentru un apartament mic, de obicei o camera de pana in 20-25 mp, un aparat de 9000 BTU este, in general, suficient. Daca alegi un aparat cu prea multi BTU, va porni si se va opri des, consumand mult curent si nu va functiona optim. Daca e prea mic, nu va raci eficient spatiul." },
  { question: "Cat de mult creste factura la curent daca folosesc aerul conditionat?", answer: "Consumul variaza mult in functie de clasa energetica a aparatului, cat de des il folosesti, temperatura setata si cat de bine este izolat apartamentul. Un aparat cu clasa energetica A+++ va consuma semnificativ mai putin decat unul cu clasa B. Daca il folosesti moderat, la o temperatura rezonabila (24-25 grade), cresterea nu ar trebui sa fie dramatica. Totusi, asteapta-te la o crestere, mai ales in lunile de vara cand il folosesti intens." },
  { question: "Pot folosi acelasi aparat pentru mai multe camere intr-un apartament mic?", answer: "In general, un aparat de aer conditionat split este proiectat sa raceasca eficient o singura camera. Daca apartamentul tau are un hol deschis sau o bucatarie integrata in living, aerul rece se poate raspandi un pic, dar nu va fi la fel de eficient. Pentru a raci mai multe camere, ai nevoie de aparate separate sau de un sistem multi-split (mai scump si mai complex)." },
  { question: "Ce inseamna functia 'inverter' la aerul conditionat?", answer: "Tehnologia inverter permite compresorului sa functioneze la viteze variabile, nu doar pornit/oprit. Asta inseamna ca aparatul ajunge mai repede la temperatura dorita, o mentine constant, consuma mai putin curent si e mai silentios. Majoritatea aparatelor moderne au aceasta tehnologie si e un mare plus." },
  { question: "Cat de des trebuie curatat aerul conditionat?", answer: "Filtrele interioare, cele pe care le vezi cand deschizi capacul unitatii interioare, ar trebui curatate o data pe luna, mai ales in sezonul cald cand le folosesti des. Acestea se pot spala cu apa. Periodic (o data pe an, de preferat inainte de sezonul cald), se recomanda o igienizare profesionala a intregului aparat, inclusiv a vaporizatorului si a clapelor, pentru a elimina bacteriile si mucegaiul." },
  { question: "Pot monta singur aerul conditionat?", answer: "Nu, montarea unui aer conditionat split necesita cunostinte tehnice specifice si unelte speciale. Este absolut necesar sa apelezi la o firma autorizata pentru instalare. O instalare incorecta poate duce la defectarea aparatului, pierderi de freon, zgomote neplacute si chiar pericole. De asemenea, garantia aparatului este conditionata de instalarea profesionala." }
];

const toc = [
  { title: "De ce ai nevoie de aer conditionat, chiar si intr-un apartament mic?", id: "de-ce-ai-nevoie-de-aer-conditionat-chiar-si-intr-un-apartament-mic" },
  { title: "Topul meu: Aparate de aer conditionat recomandate pentru apartamente mici", id: "topul-meu-aparate-de-aer-conditionat-recomandate-pentru-apartamente-mici" },
  { title: "Cum alegi aerul conditionat potrivit pentru tine: Criterii esentiale", id: "cum-alegi-aerul-conditionat-potrivit-pentru-tine-criterii-esentiale" },
  { title: "Avantaje si dezavantaje: Ce castigi si ce pierzi?", id: "avantaje-si-dezavantaje-ce-castigi-si-ce-pierzi" },
  { title: "Sfaturi practice: Trucuri din experienta mea", id: "sfaturi-practice-trucuri-din-experienta-mea" },
  { title: "Parerea mea: Alegerea finala pentru apartamentul tau", id: "parerea-mea-alegerea-finala-pentru-apartamentul-tau" }
];

// Get all articles for similar articles component
const allArticles = keywordsData.completed.map(item => ({
  title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
  slug: item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, ''),
  excerpt: item.excerpt || '',
  image: `/images/articles/${item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}.webp`,
  category: item.category,
  categorySlug: item.categorySlug,
  date: item.date || new Date().toISOString()
}));
---

