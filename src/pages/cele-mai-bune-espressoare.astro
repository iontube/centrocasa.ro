---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import SimilarArticles from '../components/SimilarArticles.astro';
import PrevNextNav from '../components/PrevNextNav.astro';
import emag from '../data/emag-products.json';
import keywordsData from '../../keywords.json';
import { visibleArticles, slugify } from '../lib/articles.mjs';

const relatedArticles = visibleArticles(keywordsData.completed).map(item => ({
  title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
  slug: item.slug || slugify(item.keyword),
  excerpt: item.excerpt || '',
  image: item.image || `/images/articles/${item.slug || slugify(item.keyword)}.webp`,
  category: item.category,
  categorySlug: item.categorySlug,
  date: item.date || '',
}));

const pool = emag.espressor || [];
const byId = Object.fromEntries(pool.map(p => [p.id, p]));

// Selectia editoriala: id + badge + specs + avantaje/dezavantaje + verdict (datele pret/rating/imagine vin LIVE din pool)
const PICKS = [
  { id: 'DZBL1HMBM', badge: 'Alegerea noastra',
    specs: ['rasnita cu 13 trepte', '4 bauturi', 'spumare manuala', '15 bar'],
    pros: ['Cel mai vandut, sute de recenzii bune', 'Rasnita reglabila pe 13 trepte', 'Simplu de folosit si de intretinut'],
    cons: ['Spuma de lapte se face manual, cu duza', 'Fara ecran tactil'],
    verdict: 'Cel mai vandut espressor cu boabe si cea mai sigura alegere pentru majoritatea oamenilor. Rasnita cu 13 trepte iti lasa control real asupra macinarii, iar cele patru bauturi acopera nevoile de zi cu zi. Spuma de lapte o faci manual, cu duza, deci pentru cappuccino ai nevoie de putin exercitiu. In rest e simplu de folosit, usor de curatat si are cel mai bun istoric de pareri din aceasta selectie. Daca nu vrei sa te complici, aici te opresti.' },
  { id: 'DZ7Q2YBBM', badge: 'Cel mai bun raport',
    specs: ['rasnita din metal, 3 trepte', '4 tipuri de cafea', 'spumare manuala', '15 bar'],
    pros: ['Cel mai ieftin automat cu rasnita', 'Rasnita din metal, robusta', 'Compact, incape usor pe blat'],
    cons: ['Rasnita are doar 3 trepte de macinare', 'Spuma de lapte manuala, cu duza'],
    verdict: 'Cel mai ieftin mod de a trece de la cafea la filtru la espresso din boabe proaspat macinate. Are rasnita din metal, robusta, dar cu doar 3 trepte de reglaj, deci nu ajustezi la fel de fin ca la De Longhi. Spuma de lapte se face manual, cu duza laterala. E compact, incape usor pe blat si merge ani buni fara batai de cap. Pentru espresso simplu de dimineata, la cel mai mic pret, e alegerea corecta.' },
  { id: 'D3YF31BBM', badge: 'Fara decalcifiere des',
    specs: ['filtru AquaClean', 'rasnita ceramica, 12 trepte', 'ecran tactil', '2 bauturi'],
    pros: ['Cu filtrul AquaClean nu decalcifiezi pana la 5000 de cafele', 'Rasnita ceramica, silentioasa', 'Ecran tactil simplu'],
    cons: ['Spuma de lapte se face manual, nu are LatteGo', 'Doar 2 bauturi presetate'],
    verdict: 'Philips seria 2200 de baza, cu un atu real: filtrul AquaClean. Daca il schimbi cand ti-o cere aparatul, nu decalcifiezi pana la 5000 de cafele, adica ani de zile. Rasnita e ceramica, silentioasa si reglabila pe 12 trepte, iar comanda se face pe ecran tactil. Partea slaba e laptele: are spumare clasica, manuala, nu sistemul LatteGo de pe modelele mai scumpe, si vine cu doar 2 bauturi presetate. Il iei daca bei mai ales espresso si vrei intretinere minima.' },
  { id: 'DY9FC8MBM', badge: 'Cappuccino automat',
    specs: ['carafa de lapte LatteCrema', '5 bauturi', 'spumare automata', 'rasnita 13 trepte'],
    pros: ['Cappuccino si latte la un buton, din carafa', 'Carafa se pune direct la frigider', 'Ecran tactil cu 5 retete'],
    cons: ['Mai scump decat modelele cu spumare manuala', 'Carafa cere spalare dupa folosire'],
    verdict: 'Aici primesti cappuccino si latte fara sa inveti spumarea manuala. Sistemul LatteCrema amesteca singur lapte, aer si abur din carafa, iar carafa se pune direct la frigider intre folosiri. Ecranul tactil are 5 retete la un buton, de la espresso la My Latte, iar rasnita cu 13 trepte pastreaza controlul asupra cafelei. Costa mai mult decat modelele cu spumare manuala si carafa cere spalata dupa folosire. Pentru bauturi cu lapte zilnice, e cel mai comod din selectie.' },
  { id: 'DDN2CMMBM', badge: 'Premium',
    specs: ['sistem LatteGo', 'ecran tactil', 'rasnita ceramica, 12 trepte', 'filtru AquaClean'],
    pros: ['LatteGo, doua piese, se spala la masina de vase', 'Ecran tactil si 3 intensitati', 'AquaClean, decalcifiere rara'],
    cons: ['Cel mai scump din selectie', 'Doar 3 bauturi presetate'],
    verdict: 'Cel mai complet Philips din acest top si cel mai scump. Are sistemul LatteGo, format din doua piese fara tuburi, care se spala in cateva secunde sau la masina de vase, deci partea de lapte nu mai e o corvoada. Adauga ecran tactil, filtru AquaClean pentru decalcifiere rara si rasnita ceramica pe 12 trepte, cu 3 intensitati. Are doar 3 bauturi presetate, dar acopera espresso, cafea lunga si cappuccino. Il alegi daca bei des bauturi cu lapte si nu vrei sa pierzi timp cu curatarea.' },
  { id: 'DW0WN8BBM', badge: 'Cel mai ieftin',
    specs: ['cu capsule Dolce Gusto', '15 bar', 'compact, 14 cm latime', 'peste 40 de bauturi'],
    pros: ['Cel mai mic pret din top', 'Ocupa foarte putin loc pe blat', 'Peste 40 de bauturi la capsula, gata in 40 de secunde'],
    cons: ['Foloseste capsule, cost pe termen lung', 'Nu macina boabe, nu e espresso din rasnita'],
    verdict: 'Nu e espressor cu boabe, ci cu capsule, si e cel mai ieftin din top. Pui capsula, apesi si in 40 de secunde ai bautura, cu peste 40 de variante disponibile, de la espresso la cappuccino sau ciocolata calda. E foarte compact, doar 14 cm latime, deci incape oriunde pe blat. Compromisul e costul pe termen lung, pentru ca platesti mereu capsule, iar cafeaua nu vine din boabe proaspat macinate. Il iei pentru simplitate si pret mic, nu pentru espresso ca la cafenea.' },
].map(x => ({ ...x, p: byId[x.id] })).filter(x => x.p);

const site = 'https://centrocasa.ro';
const hero = '/imagini/articole/espressoare.webp';
const figBuget = '/imagini/articole/espressoare-buget.webp';
const figPremium = '/imagini/articole/espressoare-premium.webp';
const published = '2026-07-16T20:10:00+03:00';

const faq = [
  { question: 'Ce espressor automat sa aleg?', answer: 'Pentru cei mai multi oameni, De Longhi Magnifica S e cea mai sigura alegere: are cel mai bun istoric de pareri, rasnita reglabila si e usor de folosit. Daca vrei cel mai mic pret cu rasnita, ia Krups Espresseria; daca bei mult cappuccino, un model cu LatteGo sau cu carafa de lapte iti scuteste timpul de curatare.' },
  { question: 'Cat costa un espressor automat bun?', answer: 'Un espressor automat cu rasnita, bun, incepe pe la 950-1000 de lei (Krups Espresseria) si merge pana la 3000 de lei pentru modele cu ecran, sistem de lapte si multe retete. Zona cu cel mai bun raport e 1200-1800 de lei. Sub 500 de lei gasesti doar aparate cu capsule, nu cu boabe.' },
  { question: 'Care e diferenta dintre espressor automat si unul cu capsule?', answer: 'Un espressor automat macina boabele proaspat, preseaza cafeaua si prepara espresso la apasarea unui buton, deci cafeaua e mai buna si mai ieftina pe termen lung. Unul cu capsule, ca Dolce Gusto, e mai ieftin la cumparare si foarte simplu, dar cafeaua vine din capsule cumparate mereu, deci costa mai mult in timp.' },
  { question: 'Ce inseamna sistemul LatteGo de la Philips?', answer: 'LatteGo e sistemul de spumare a laptelui de la Philips, format din doar doua piese, fara tuburi. Se spala in cateva secunde sub jet de apa, spre deosebire de sistemele clasice cu tuburi care se infunda. E cel mai comod de intretinut daca bei des bauturi cu lapte.' },
  { question: 'Cat de des trebuie curatat un espressor automat?', answer: 'Grupul de infuzare si sistemul de lapte se clatesc zilnic sau dupa fiecare folosire cu lapte. Decalcifierea completa se face de obicei la 2-3 luni sau la cateva sute de cafele, in functie de duritatea apei. Modelele cu AquaClean sau cu sisteme usor de scos, ca LatteGo, cer mai putin efort.' },
  { question: 'Cat de des trebuie sa decalcifiez espressorul?', answer: 'In general la 2-3 luni, sau atunci cand aparatul iti cere singur, in functie de cat de dura e apa si de cat de des il folosesti. Un espressor folosit de mai multe ori pe zi cu apa dura are nevoie de decalcifiere mai des. Modelele cu filtru AquaClean amana decalcifierea pana la 5000 de cafele, iar apa filtrata reduce depunerile de calcar.' },
  { question: 'Merita un espressor cu ecran si multe retete?', answer: 'Doar daca in casa fiecare bea altceva sau vrei des bauturi cu lapte diferite, ca latte macchiato sau cappuccino. Daca bei aceeasi cafea in fiecare zi, un model cu doua butoane face aceeasi treaba la un pret mai mic. Ecranul si retetele presetate sunt confort, nu o conditie pentru o cafea buna.' },
];

const images = [hero, figBuget, figPremium, ...PICKS.map(x => x.p.image)];
const money = (n) => n.toLocaleString('ro-RO');
const b64 = (s) => Buffer.from(s).toString('base64');
---

<Layout
  title="Cele mai bune espressoare automate in 2026: 6 modele testate (De Longhi, Philips, Krups)"
  description="Ce espressor automat sa iti iei in 2026: 6 modele comparate pe pret, rasnita, sistem de lapte si pareri reale, de la Krups Espresseria la Philips premium. Plus cum alegi si cat costa."
  image={hero}
  type="article"
  publishedTime={published}
  modifiedTime={published}
  author="Cristian Popa"
  breadcrumb={[{ name: 'Acasa', url: '/' }, { name: 'Electrocasnice Casa', url: '/electrocasnice-casa/' }, { name: 'Cele mai bune espressoare' }]}
  faq={faq.map(f => ({ question: f.question, answer: f.answer }))}
>
  <article class="rd">
    <nav class="breadcrumb">
      <a href="/">Acasa</a><span class="breadcrumb-separator">/</span>
      <a href="/electrocasnice-casa/">Electrocasnice Casa</a><span class="breadcrumb-separator">/</span>
      <span>Cele mai bune espressoare</span>
    </nav>

    <h1>Cele mai bune espressoare automate in 2026</h1>
    <p class="rd-byline">de <a href="/autori/cristian-popa/">Cristian Popa</a>, Specialist Electrocasnice · actualizat iulie 2026</p>

    <img class="rd-hero" src={hero} alt="Cele mai bune espressoare automate: De Longhi, Philips si Krups" width="1200" height="675" fetchpriority="high" />

    <div class="rd-intro">
      <p>Cel mai bun espressor automat pentru majoritatea oamenilor este <strong>De Longhi Magnifica S</strong>: are rasnita reglabila pe 13 trepte, e simplu de folosit si are cel mai bun istoric de pareri. Daca vrei acelasi lucru mai ieftin, ia <strong>Krups Espresseria</strong>, iar daca bei des cappuccino, un model cu sistem de lapte automat ca <strong>Philips cu LatteGo</strong> sau <strong>De Longhi Evo Milk</strong> iti scuteste timpul de curatare.</p>
      <p>Mai jos ai 6 espressoare comparate pe pret, rasnita, sistemul de lapte si parerile reale ale cumparatorilor, pentru bugete de la 300 la 3000 de lei. Alege in functie de cat de des bei bauturi cu lapte si de cat vrei sa te implici in preparare.</p>
      <p>Am pornit de la cele mai vandute espressoare de pe eMAG, am verificat specificatiile reale ale fiecarui model, de la numarul de trepte al rasnitei la sistemul de lapte si modul de intretinere, si le-am comparat cu parerile a mii de cumparatori. Nu insiram doar cifre de pe cutie, ci explicam ce inseamna fiecare in folosirea de zi cu zi.</p>
    </div>

    <details class="rd-toc">
      <summary>Cuprins</summary>
      <ol>
        <li><a href="#pe-scurt">Care espressor pentru cine</a></li>
        <li><a href="#produse">Cele 6 espressoare pe larg</a></li>
        <li><a href="#boabe-capsule">Espressor cu boabe sau cu capsule</a></li>
        <li><a href="#cum-alegi">Cum alegi cel mai bun espressor</a></li>
        <li><a href="#greseli">Greseli frecvente la cumparare</a></li>
        <li><a href="#cat-costa">Cat costa un espressor</a></li>
        <li><a href="#intretinere">Cum ai grija de espressor</a></li>
        <li><a href="#faq">Intrebari frecvente</a></li>
      </ol>
    </details>

    <h2 id="pe-scurt">Pe scurt: care espressor pentru cine</h2>
    <p>Daca esti grabit, tabelul de mai jos rezuma pentru cine e potrivit fiecare model si cat costa. Preturile si numarul de recenzii sunt luate direct de pe eMAG.</p>
    <div class="table-wrap">
      <table class="rd-table">
        <thead><tr><th>Model</th><th>Cel mai bun la</th><th>Pret</th><th>Pareri</th></tr></thead>
        <tbody>
          {PICKS.map(x => (
            <tr>
              <td>{x.p.name.replace(/’/g, "'").split(',')[0]}</td>
              <td>{x.badge}</td>
              <td>{money(x.p.price)} lei</td>
              <td>{x.p.rating ? `${x.p.rating.toFixed(2)} (${x.p.reviews})` : '-'}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <h2 id="produse">Cele 6 espressoare pe larg</h2>
    <p>Le-am aranjat de la cea mai echilibrata alegere la cea mai ieftina. Fiecare card are pretul, ratingul si numarul de recenzii direct de pe eMAG, plus avantajele si dezavantajele pe scurt.</p>
    <div class="rd-grid">
      {PICKS.map(x => (
        <ProductCard
          name={x.p.name.replace(/’/g, "'")}
          image={x.p.image}
          price={x.p.price}
          rating={x.p.rating}
          reviews={x.p.reviews}
          badge={x.badge}
          specs={x.specs}
          pros={x.pros}
          cons={x.cons}
          verdict={x.verdict}
          outKey={'p-' + x.id}
        />
      ))}
    </div>

    <img class="rd-fig" src={figBuget} alt="Espressoare bune sub 1500 de lei: Krups, Dolce Gusto, Philips" width="1200" height="675" loading="lazy" />

    <h2 id="boabe-capsule">Espressor cu boabe sau cu capsule?</h2>
    <p>E prima intrebare de pus inainte sa te uiti la modele, pentru ca sunt doua tipuri complet diferite de aparate, cu costuri si rezultate diferite.</p>
    <p><strong>Espressorul cu boabe</strong> macina cafeaua proaspat la fiecare ceasca. Costa mai mult la cumparare, dar cafeaua iese mai buna si mai ieftina pe termen lung. Il alegi daca:</p>
    <ul>
      <li>Bei cafea in fiecare zi si vrei cel mai bun gust</li>
      <li>Vrei sa reglezi taria, cantitatea si finetea macinarii</li>
      <li>Nu te deranjeaza sa cureti si sa decalcifiezi aparatul periodic</li>
    </ul>
    <p><strong>Espressorul cu capsule</strong>, ca Dolce Gusto, e ieftin si simplu: pui capsula, apesi, gata. Compromisul e costul pe termen lung, o capsula costa in jur de 1 pana la 2 lei, si nu ai control asupra cafelei. Il alegi daca:</p>
    <ul>
      <li>Vrei cel mai mic pret de pornire si zero bataie de cap</li>
      <li>Bei ocazional si nu te deranjeaza costul per capsula</li>
      <li>Iti place varietatea de bauturi gata dozate, inclusiv ciocolata calda sau ceai</li>
    </ul>
    <p>Pe scurt: pe boabe daca bei zilnic si vrei cafea buna, ieftina in timp; pe capsule daca vrei simplitate si pret mic la cumparare. Restul articolului se concentreaza pe espressoarele cu boabe, acolo unde alegerea conteaza cel mai mult.</p>

    <h2 id="cum-alegi">Cum alegi cel mai bun espressor</h2>
    <p>Pretul conteaza, dar cateva lucruri fac ca un espressor sa fie placut sau enervant in fiecare zi. Uite pe ce sa te uiti inainte sa cumperi.</p>

    <h3>Rasnita: cu boabe, nu cu capsule</h3>
    <p>Un espressor automat adevarat macina boabele pe loc, chiar inainte de extractie. De aici vine aroma proaspata pe care nu o ai de la cafeaua deja macinata sau de la capsule.</p>
    <p>Conteaza numarul de trepte de reglaj: cu cat sunt mai multe, cu atat ajustezi mai fin cat de tare iese cafeaua. De Longhi Magnifica S are 13 trepte, Krups Espresseria doar 3. Rasnitele ceramice sunt mai silentioase si nu incing cafeaua, cele din metal sunt robuste, dar mai zgomotoase.</p>

    <h3>Sistemul de lapte</h3>
    <p>Aici e cea mai mare diferenta de confort daca bei cappuccino sau latte. Exista trei variante, de la cea mai ieftina la cea mai comoda.</p>
    <p>Spumarea manuala, cu o duza de abur, e cea mai ieftina, dar o faci singur de fiecare data si cere putin exercitiu. Sistemul LatteGo de la Philips e o camera din doua piese, fara tuburi, care se spala in cateva secunde sau la masina de vase.</p>
    <p>Cel mai comod e o carafa automata, ca sistemul LatteCrema de la De Longhi: face spuma singura, la un buton, si se pune direct la frigider intre folosiri. Daca bei espresso simplu, spumarea manuala ajunge; daca bei des bauturi cu lapte, un sistem automat iti scuteste timp real.</p>

    <h3>Intretinerea si decalcifierea</h3>
    <p>Orice espressor cere clatire dupa folosire si decalcifiere periodica, altfel se infunda si se strica in timp.</p>
    <p>Filtrul AquaClean de la Philips amana decalcifierea pana la 5000 de cafele, adica ani de zile, daca schimbi filtrul cand ti-o cere aparatul. Un grup de infuzare detasabil, ca la De Longhi, il scoti si il speli sub apa, mult mai simplu decat la aparatele cu grup fix, care se curata doar cu solutii.</p>

    <h3>Cate bauturi presetate iti trebuie</h3>
    <p>Modelele de baza fac espresso si cafea lunga, cu doua butoane. Cele mai scumpe adauga cappuccino, latte macchiato si alte retete la un buton, pe ecran tactil.</p>
    <p>Daca bei aceeasi cafea in fiecare zi, doua bauturi sunt destule. Daca in casa fiecare bea altceva, un model cu mai multe retete presetate chiar are sens.</p>

    <h3>Presiunea si rezervoarele</h3>
    <p>Aproape toate espressoarele bune au 15 bar, presiunea standard pentru un espresso cu crema densa, asa ca nu e un criteriu care sa te ajute sa alegi intre ele. Nu te lasa impresionat de cifra, o au toate.</p>
    <p>Uita-te mai degraba la rezervorul de apa, in jur de 1.6 - 1.8 litri la modelele din acest top, si la containerul de boabe. Cu cat sunt mai mari, cu atat reumpli mai rar, ceea ce conteaza daca sunteti mai multi bautori de cafea in casa.</p>

    <h2 id="greseli">Greseli frecvente cand cumperi un espressor</h2>
    <p>Cateva capcane in care cad multi cumparatori si cum le eviti:</p>
    <ul>
      <li><strong>Te iei dupa numarul de bari.</strong> Toate espressoarele bune au 15 bar, il au si aparatele slabe, deci nu e un semn de calitate care sa te ajute sa alegi.</li>
      <li><strong>Cumperi cu capsule crezand ca e cu boabe.</strong> Verifica sa scrie rasnita sau boabe in descriere, altfel vei plati capsule la nesfarsit.</li>
      <li><strong>Ignori sistemul de lapte.</strong> Daca bei cappuccino zilnic si iei un model cu spumare manuala, te va enerva in fiecare dimineata.</li>
      <li><strong>Uiti de intretinere.</strong> Un espressor fara decalcifiere se infunda si se strica; alege unul cu grup detasabil sau cu AquaClean daca vrei efort minim.</li>
      <li><strong>Platesti pentru retete de care nu ai nevoie.</strong> Daca bei mereu aceeasi cafea, un model cu doua bauturi e suficient si mai ieftin decat unul cu ecran si zece retete.</li>
    </ul>

    <h2 id="cat-costa">Cat costa un espressor automat</h2>
    <p>Pragurile arata cam asa in 2026:</p>
    <p><strong>Pana in 500 de lei</strong> gasesti doar aparate cu capsule, ca Dolce Gusto. Simple si ieftine, dar cu cost recurent la capsule si fara cafea din rasnita.</p>
    <p><strong>950 - 1500 de lei</strong> e zona cu cel mai bun raport: espressoare automate cu rasnita, ca Krups Espresseria sau De Longhi Magnifica S. De aici incepe cafeaua adevarata din boabe.</p>
    <p><strong>1600 - 3000 de lei</strong> aduce sisteme de lapte automate, ecran si mai multe retete, ca la Philips seria 2200 sau De Longhi Evo Milk. Platesti pentru confort si bauturi cu lapte la un buton.</p>
    <p>Dincolo de pretul aparatului, conteaza si costul cafelei in sine. O capsula Dolce Gusto costa in jur de 1 pana la 2 lei bautura, in timp ce un espresso din boabe iese de obicei sub 1 leu. Peste cateva sute de cafele, diferenta acopera o buna parte din pretul unui espressor cu rasnita, motiv pentru care pe termen lung boabele ies mai ieftine.</p>

    <img class="rd-fig" src={figPremium} alt="Espressoare premium cu sistem de lapte: De Longhi si Philips" width="1200" height="675" loading="lazy" />

    <h2 id="intretinere">Cum ai grija de espressor ca sa dureze</h2>
    <p>Un espressor bine intretinut merge ani buni, unul neglijat se infunda si face cafea proasta. Rutina e simpla si merita respectata.</p>
    <ul>
      <li><strong>Zilnic:</strong> clateste sistemul de lapte si duza dupa fiecare bautura cu lapte, si goleste tava de scurgere.</li>
      <li><strong>Saptamanal:</strong> scoate si spala grupul de infuzare, acolo unde e detasabil, si sterge rezervorul de apa.</li>
      <li><strong>La 2-3 luni:</strong> decalcifiaza aparatul, sau atunci cand ti-o cere singur, in functie de cat de dura e apa si de cat de des il folosesti.</li>
    </ul>
    <p>Doua lucruri usureaza mult treaba: un grup de infuzare detasabil, care se spala sub apa, si un filtru ca AquaClean, care amana decalcifierea pana la 5000 de cafele. Daca folosesti apa filtrata sau plata in loc de apa de la robinet, calcarul se depune mai greu si decalcifiezi mai rar.</p>

    <div class="rd-offers" data-o={b64('oferte-espressoare')} role="button" tabindex="0">
      <div class="rd-offers-txt">
        <strong>Vezi toate espressoarele automate la oferta</strong>
        <span>Reducerile din acest moment la espressoare automate, direct pe eMAG</span>
      </div>
      <span class="rd-offers-btn">Vezi ofertele
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </span>
    </div>

    <h2 id="faq">Intrebari frecvente</h2>
    <div class="rd-faq">
      {faq.map(f => (
        <details class="rd-faq-item">
          <summary>{f.question}</summary>
          <p>{f.answer}</p>
        </details>
      ))}
    </div>

    <div class="author-box">
      <div class="author-avatar">CP</div>
      <div class="author-info">
        <p class="author-name"><a href="/autori/cristian-popa/" class="author-name-link">Cristian Popa</a></p>
        <p class="author-role">Specialist Electrocasnice</p>
