---
import Layout from '../layouts/Layout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import keywordsData from '../../keywords.json';
import { visibleArticles } from '../lib/articles.mjs';
import { categories } from '../lib/categories.mjs';

// Get completed articles (fara cele legacy, cand exista articole noi)
const articles = visibleArticles(keywordsData.completed).map(item => ({
  title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
  slug: item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, ''),
  excerpt: item.excerpt || '',
  image: item.image || `/images/articles/${item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}.webp`,
  category: item.category,
  categorySlug: item.categorySlug,
  date: item.date || new Date().toISOString()
})).sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

// Count articles per category
const categoryCounts = categories.map(cat => ({
  ...cat,
  count: articles.filter(a => a.categorySlug === cat.slug).length
}));

// Sectiuni pe categorie: cele mai noi 9 articole per categorie (newest first) + link catre toata categoria
const sections = categories
  .map(cat => ({
    ...cat,
    count: articles.filter(a => a.categorySlug === cat.slug).length,
    items: articles.filter(a => a.categorySlug === cat.slug).slice(0, 9)
  }))
  .filter(s => s.items.length > 0);
---

<Layout
  title="CentroCasa - Sfaturi si Recomandari pentru Casa si Gradina"
  description="Descopera cele mai bune produse si sfaturi pentru casa si gradina ta. Ghiduri de cumparare, recenzii si recomandari de la experti."
>
  <!-- Hero Section -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <h1>Recenzii si sfaturi pentru casa si gradina</h1>
        <p>
          Ghiduri de cumparare, comparatii si recomandari testate, ca sa alegi
          produsele potrivite fara batai de cap.
        </p>
      </div>
    </div>
  </section>

  <!-- Sectiuni pe categorie: 9 articole per categorie + link catre toata categoria -->
  {sections.map((section, i) => (
    <section class="section" style={i % 2 === 0 ? 'background: var(--color-gray-100);' : ''}>
      <div class="container">
        <div class="section-header section-header--row">
          <div>
            <h2 class="section-title">{section.name}</h2>
          </div>
          <a href={`/${section.slug}/`} class="section-see-all">
            Vezi toate ({section.count})
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="articles-grid">
          {section.items.map(article => (
            <ArticleCard {...article} />
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- Despre CentroCasa -->
  <section class="section about">
    <div class="container">
      <div class="about-head">
        <h2 class="section-title">Despre CentroCasa</h2>
        <p class="about-lead">Te ajutam sa alegi cele mai bune produse pentru casa si gradina, cu recomandari sincere bazate pe specificatii reale si pe parerile a mii de cumparatori. Comparam, verificam si explicam pe intelesul tuturor, ca tu sa economisesti timp si bani.</p>
      </div>
      <div class="about-grid">
        <div class="about-card">
          <div class="about-icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
          </div>
          <h3>Analiza pe date reale</h3>
          <p>Comparam specificatiile reale ale fiecarui produs, nu doar cifrele de pe cutie.</p>
        </div>
        <div class="about-card">
          <div class="about-icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l2.9 6.3 6.9.6-5.2 4.6 1.6 6.8L12 17.3 5.8 20.9l1.6-6.8L2.2 8.9l6.9-.6z"/></svg>
          </div>
          <h3>Pareri reale</h3>
          <p>Ne uitam la parerile a mii de cumparatori, nu doar la descrierea producatorului.</p>
        </div>
        <div class="about-card">
          <div class="about-icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
          </div>
          <h3>Recomandari sincere</h3>
          <p>Nu suntem sponsorizati de producatori si nu favorizam anumite branduri.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .section-header--row { display: flex; justify-content: space-between; align-items: flex-end; gap: 1.5rem; text-align: left; }
  .section-header--row .section-subtitle { max-width: 640px; }
  .section-see-all { flex: 0 0 auto; display: inline-flex; align-items: center; gap: .35rem; color: var(--color-primary-700, #15803d); font-weight: 600; text-decoration: none; white-space: nowrap; }
  .section-see-all:hover { text-decoration: underline; }
  .section-footer { text-align: center; margin-top: 2rem; }
  .section-see-all-btn { display: inline-block; padding: .7rem 1.6rem; border: 1px solid var(--color-primary-600, #16a34a); color: var(--color-primary-700, #15803d); border-radius: 10px; font-weight: 600; text-decoration: none; transition: background .15s, color .15s; }
  .section-see-all-btn:hover { background: var(--color-primary-600, #16a34a); color: #fff; }
  @media (max-width: 640px) {
    .section-header--row { flex-direction: column; align-items: flex-start; }
  }

  .about { background: linear-gradient(135deg, var(--color-primary-800, #166534) 0%, var(--color-primary-900, #14532d) 100%); }
  .about-head { text-align: center; max-width: 680px; margin: 0 auto 2.5rem; }
  .about-head .section-title { color: #fff; margin-bottom: .5rem; }
  .about-lead { color: rgba(255,255,255,.85); font-size: 1.05rem; line-height: 1.7; margin: 0; }
  .about-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem; max-width: 960px; margin: 0 auto; }
  .about-card { background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.14); border-radius: 14px; padding: 1.9rem 1.6rem; text-align: center; }
  .about-icon { width: 54px; height: 54px; margin: 0 auto 1.1rem; border-radius: 13px; background: rgba(255,255,255,.12); color: var(--color-primary-300, #86efac); display: flex; align-items: center; justify-content: center; }
  .about-card h3 { color: #fff; font-size: 1.12rem; margin: 0 0 .45rem; }
  .about-card p { color: rgba(255,255,255,.78); font-size: .93rem; line-height: 1.6; margin: 0; }
</style>
