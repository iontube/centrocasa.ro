  { title: "Banca de gradina din lemn masiv de brad tratat \"Veranda\"", id: "banca-de-gradina-din-lemn-masiv-de-brad-tratat-veranda" },
  { title: "Banca de gradina din lemn masiv de eucalipt \"Zenith\"", id: "banca-de-gradina-din-lemn-masiv-de-eucalipt-zenith" },
