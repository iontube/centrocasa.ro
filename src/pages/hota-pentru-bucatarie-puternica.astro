  { title: "Pe ce sa te uiti cand cauti o hota de bucatarie performanta", id: "pe-ce-sa-te-uiti-cand-cauti-o-hota-de-bucatarie-performanta" },
  { title: "Hota telescopica vs. hota decorativa: ce sa alegi", id: "hota-telescopica-vs-hota-decorativa-ce-sa-alegi" },
  { title: "Greseli de evitat la achizitia unei hote", id: "greseli-de-evitat-la-achizitia-unei-hote" },
