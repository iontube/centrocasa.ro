---
// Card de produs orizontal pentru roundup-uri. Datele LIVE (pret/rating/recenzii/imagine)
// vin din src/data/emag-products.json; badge/avantaje/dezavantaje/recenzie sunt scrise in articol.
interface Props {
  name: string;
  image: string;
  price: number;
  currency?: string;
  rating?: number | null;
  reviews?: number;
  badge?: string;
  pros?: string[];
  cons?: string[];
  verdict?: string;        // recenzie, 3-5 propozitii
  outKey: string;
  specs?: string[];
}
const { name, image, price, currency = 'RON', rating = null, reviews = 0, badge, pros = [], cons = [], verdict = '', outKey, specs = [] } = Astro.props;
const stars = rating ? Math.round(rating) : 0;
const b64 = (s) => Buffer.from(s).toString('base64');
// sparge recenzia in paragrafe mici (cate ~2 propozitii)
const verdictParas = (() => {
  const s = (verdict.match(/[^.!?]+[.!?]+/g) || (verdict ? [verdict] : [])).map(x => x.trim());
  const out = [];
  for (let i = 0; i < s.length; i += 2) out.push(s.slice(i, i + 2).join(' '));
  return out;
})();
---

<article class="pcard">
  <div class="pcard-media">
    <img src={image} alt={name} loading="lazy" width="240" height="240" />
  </div>
  <div class="pcard-body">
    {badge && <span class="pcard-badge">{badge}</span>}
    <h3 class="pcard-name">{name}</h3>

    <div class="pcard-meta">
      {rating && (
        <span class="pcard-rating" title={`${rating} din 5`}>
          <span class="pcard-stars" aria-hidden="true">{'★★★★★'.slice(0, stars)}<span class="pcard-stars-off">{'★★★★★'.slice(stars)}</span></span>
          <span class="pcard-rval">{rating.toFixed(2)}</span>
          {reviews > 0 && <span class="pcard-reviews">({reviews} recenzii)</span>}
        </span>
      )}
      <span class="pcard-price">{price.toLocaleString('ro-RO')} {currency === 'RON' ? 'lei' : currency}</span>
    </div>

    {specs.length > 0 && (
      <ul class="pcard-specs">{specs.map(s => <li>{s}</li>)}</ul>
    )}

    {verdictParas.length > 0 && (
      <div class="pcard-verdict">{verdictParas.map(p => <p>{p}</p>)}</div>
    )}

    {(pros.length > 0 || cons.length > 0) && (
      <div class="pcard-pc">
        {pros.length > 0 && (
          <div class="pcard-pros"><span class="pcard-pc-h">Avantaje</span><ul>{pros.map(p => <li>{p}</li>)}</ul></div>
        )}
        {cons.length > 0 && (
          <div class="pcard-cons"><span class="pcard-pc-h">Dezavantaje</span><ul>{cons.map(c => <li>{c}</li>)}</ul></div>
        )}
      </div>
    )}

    <button class="pcard-buy" type="button" data-o={b64(outKey)}>
      Vezi pretul pe eMAG
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </button>
  </div>
</article>

<style>
  .pcard { display: flex; gap: 1.4rem; background: #fff; border: 1px solid var(--color-gray-200, #e7e5e4); border-radius: var(--radius-md, 10px); overflow: hidden; box-shadow: var(--shadow-card); padding: 1.25rem; }
  .pcard-media { flex: 0 0 220px; display: flex; align-items: center; justify-content: center; background: #fff; }
  .pcard-media img { width: 100%; max-width: 220px; height: 220px; object-fit: contain; }
  .pcard-body { flex: 1; min-width: 0; display: flex; flex-direction: column; }
  .pcard-badge { align-self: flex-start; background: rgba(222, 91, 20, 0.12); color: var(--color-accent-700, #b84412); font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .03em; padding: .28rem .6rem; border-radius: 6px; margin-bottom: .5rem; }
  .pcard-name { font-size: 1.18rem; line-height: 1.3; margin: 0 0 .55rem; }
  .pcard-meta { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; margin-bottom: .7rem; }
  .pcard-rating { display: inline-flex; align-items: center; gap: .3rem; font-size: .84rem; color: var(--color-gray-600, #57534e); }
  .pcard-stars { color: #f5a623; letter-spacing: 1px; }
  .pcard-stars-off { color: #d6d3d1; }
  .pcard-rval { font-weight: 700; color: var(--color-gray-800); }
  .pcard-price { font-size: 1.35rem; font-weight: 800; color: var(--color-primary-700, #15803d); white-space: nowrap; margin-left: auto; }
  .pcard-specs { list-style: none; padding: 0; margin: 0 0 .8rem; display: flex; flex-wrap: wrap; gap: .4rem; }
  .pcard-specs li { font-size: .78rem; background: var(--color-gray-100, #f5f5f4); color: var(--color-gray-700); padding: .25rem .55rem; border-radius: 6px; }
  .pcard-verdict { margin: 0 0 1rem; }
  .pcard-verdict p { font-size: .95rem; line-height: 1.6; color: var(--color-gray-700); margin: 0 0 .6rem; }
  .pcard-verdict p:last-child { margin-bottom: 0; }
  .pcard-pc { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem 1.5rem; margin-bottom: 1.1rem; }
  .pcard-pc-h { display: block; font-size: .74rem; font-weight: 700; text-transform: uppercase; letter-spacing: .02em; margin-bottom: .3rem; }
  .pcard-pros .pcard-pc-h { color: var(--color-primary-700, #15803d); }
  .pcard-cons .pcard-pc-h { color: #b45309; }
  .pcard-pc ul { list-style: none; padding: 0; margin: 0; }
  .pcard-pc li { font-size: .84rem; line-height: 1.45; padding-left: 1.15rem; position: relative; color: var(--color-gray-700); margin-bottom: .22rem; }
  .pcard-pros li::before { content: '+'; position: absolute; left: 0; color: var(--color-primary-600, #16a34a); font-weight: 800; }
  .pcard-cons li::before { content: '\2013'; position: absolute; left: 0; color: #b45309; font-weight: 800; }
  .pcard-buy { align-self: flex-start; margin-top: auto; display: inline-flex; align-items: center; gap: .45rem; background: var(--color-accent-600, #de5b14); color: #fff; border: 0; border-radius: 9px; padding: .75rem 1.4rem; font-weight: 700; font-size: .95rem; cursor: pointer; transition: background .15s; }
  .pcard-buy:hover { background: var(--color-accent-700, #b84412); }
  @media (max-width: 640px) {
    .pcard { flex-direction: column; gap: 1rem; }
    .pcard-media { flex: none; width: 100%; }
    .pcard-pc { grid-template-columns: 1fr; gap: .5rem; }
    .pcard-price { margin-left: 0; }
    .pcard-buy { align-self: stretch; justify-content: center; }
  }
</style>
