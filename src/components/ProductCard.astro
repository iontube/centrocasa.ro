---
// Card de produs pentru roundup-uri. Datele LIVE (pret/rating/recenzii/imagine) vin din
// src/data/emag-products.json; badge/avantaje/dezavantaje/verdict sunt scrise in articol.
interface Props {
  name: string;
  image: string;
  price: number;
  currency?: string;
  rating?: number | null;
  reviews?: number;
  badge?: string;          // "Alegerea noastra", "Cel mai bun raport", "Buget mic", "Premium"...
  pros?: string[];
  cons?: string[];
  verdict?: string;
  outKey: string;          // cheie /out (ex. "espressor-3")
  specs?: string[];        // 3-5 specs scurte
}
const { name, image, price, currency = 'RON', rating = null, reviews = 0, badge, pros = [], cons = [], verdict = '', outKey, specs = [] } = Astro.props;
const stars = rating ? Math.round(rating) : 0;
const b64 = (s) => Buffer.from(s).toString('base64');
---

<article class="pcard">
  {badge && <span class="pcard-badge">{badge}</span>}
  <div class="pcard-media">
    <img src={image} alt={name} loading="lazy" width="260" height="260" />
  </div>
  <div class="pcard-body">
    <h3 class="pcard-name">{name}</h3>
    <div class="pcard-meta">
      {rating && (
        <span class="pcard-rating" title={`${rating} din 5`}>
          <span class="pcard-stars" aria-hidden="true">{'★★★★★'.slice(0, stars)}<span class="pcard-stars-off">{'★★★★★'.slice(stars)}</span></span>
          <span class="pcard-rval">{rating.toFixed(2)}</span>
          {reviews > 0 && <span class="pcard-reviews">({reviews} recenzii)</span>}
        </span>
      )}
      <span class="pcard-price">{price.toLocaleString('ro-RO')} {currency === 'RON' ? 'lei' : currency}</span>
    </div>

    {specs.length > 0 && (
      <ul class="pcard-specs">{specs.map(s => <li>{s}</li>)}</ul>
    )}

    {(pros.length > 0 || cons.length > 0) && (
      <div class="pcard-pc">
        {pros.length > 0 && (
          <div class="pcard-pros"><span class="pcard-pc-h">Avantaje</span><ul>{pros.map(p => <li>{p}</li>)}</ul></div>
        )}
        {cons.length > 0 && (
          <div class="pcard-cons"><span class="pcard-pc-h">Dezavantaje</span><ul>{cons.map(c => <li>{c}</li>)}</ul></div>
        )}
      </div>
    )}

    {verdict && <p class="pcard-verdict">{verdict}</p>}

    <button class="pcard-buy" type="button" data-o={b64(outKey)}>
      Vezi pretul pe eMAG
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </button>
    <p class="pcard-note">Pretul se actualizeaza pe eMAG.</p>
  </div>
</article>

<style>
  .pcard { position: relative; display: flex; flex-direction: column; background: #fff; border: 1px solid var(--color-gray-200, #e7e5e4); border-radius: var(--radius-md, 10px); overflow: hidden; box-shadow: var(--shadow-card); }
  .pcard-badge { position: absolute; top: 12px; left: 12px; z-index: 2; background: var(--color-accent-600, #de5b14); color: #fff; font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .02em; padding: .32rem .6rem; border-radius: 999px; }
  .pcard-media { background: #fff; padding: 1.2rem; display: flex; align-items: center; justify-content: center; }
  .pcard-media img { width: 100%; max-width: 260px; height: 220px; object-fit: contain; }
  .pcard-body { padding: 0 1.15rem 1.15rem; display: flex; flex-direction: column; flex: 1; }
  .pcard-name { font-size: 1.05rem; line-height: 1.3; margin: 0 0 .5rem; }
  .pcard-meta { display: flex; align-items: center; justify-content: space-between; gap: .5rem; flex-wrap: wrap; margin-bottom: .7rem; }
  .pcard-rating { display: inline-flex; align-items: center; gap: .3rem; font-size: .82rem; color: var(--color-gray-600, #57534e); }
  .pcard-stars { color: #f5a623; letter-spacing: 1px; }
  .pcard-stars-off { color: #d6d3d1; }
  .pcard-rval { font-weight: 700; color: var(--color-gray-800); }
  .pcard-price { font-size: 1.15rem; font-weight: 800; color: var(--color-primary-700, #15803d); white-space: nowrap; }
  .pcard-specs { list-style: none; padding: 0; margin: 0 0 .7rem; display: flex; flex-wrap: wrap; gap: .35rem; }
  .pcard-specs li { font-size: .76rem; background: var(--color-gray-100, #f5f5f4); color: var(--color-gray-700); padding: .2rem .5rem; border-radius: 6px; }
  .pcard-pc { display: grid; grid-template-columns: 1fr 1fr; gap: .6rem; margin-bottom: .7rem; }
  .pcard-pc-h { display: block; font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .02em; margin-bottom: .2rem; }
  .pcard-pros .pcard-pc-h { color: var(--color-primary-700, #15803d); }
  .pcard-cons .pcard-pc-h { color: #b45309; }
  .pcard-pc ul { list-style: none; padding: 0; margin: 0; }
  .pcard-pc li { font-size: .8rem; line-height: 1.4; padding-left: 1.1rem; position: relative; color: var(--color-gray-700); margin-bottom: .18rem; }
  .pcard-pros li::before { content: '+'; position: absolute; left: 0; color: var(--color-primary-600, #16a34a); font-weight: 800; }
  .pcard-cons li::before { content: '–'; position: absolute; left: 0; color: #b45309; font-weight: 800; }
  .pcard-verdict { font-size: .88rem; line-height: 1.55; color: var(--color-gray-600); margin: 0 0 .9rem; }
  .pcard-buy { margin-top: auto; display: inline-flex; align-items: center; justify-content: center; gap: .4rem; width: 100%; background: var(--color-accent-600, #de5b14); color: #fff; border: 0; border-radius: 9px; padding: .8rem 1rem; font-weight: 700; font-size: .95rem; cursor: pointer; transition: background .15s; }
  .pcard-buy:hover { background: var(--color-accent-700, #b84412); }
  .pcard-note { text-align: center; font-size: .72rem; color: var(--color-gray-400); margin: .4rem 0 0; }
</style>
