---
interface Props {
  title: string;
  slug: string;
  excerpt: string;
  image: string;
  category: string;
  categorySlug: string;
  date: string;
  showExcerpt?: boolean;
}

const { title, slug, excerpt, image, category, categorySlug, date, showExcerpt = true } = Astro.props;
const rawExcerpt = (excerpt || '').replace(/<[^>]*>/g, '').trim();
const cleanExcerpt = rawExcerpt.length > 120
  ? rawExcerpt.slice(0, 120).replace(/\s+\S*$/, '') + '…'
  : rawExcerpt;

const formattedDate = new Date(date).toLocaleDateString('ro-RO', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<article class="article-card">
  <a href={`/${slug}/`}>
    <img
      src={image}
      alt={title}
      class="article-card-image"
      loading="lazy"
      width="400"
      height="220"
    >
  </a>
  <div class="article-card-content">
    <div class="article-card-meta">
      <a href={`/${categorySlug}/`} class="article-card-category">{category}</a>
      <span class="article-card-date">{formattedDate}</span>
    </div>
    <h3><a href={`/${slug}/`}>{title}</a></h3>
    {showExcerpt && <p class="article-card-excerpt">{cleanExcerpt}</p>}
    <a href={`/${slug}/`} class="read-more">
      Citeste articolul
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>
  </div>
</article>
