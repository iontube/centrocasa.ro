---
const currentYear = new Date().getFullYear();

const categories = [
  { name: 'Gradinarit si Unelte', slug: 'gradinarit-unelte' },
  { name: 'Mobilier Gradina', slug: 'mobilier-gradina' },
  { name: 'Electrocasnice Casa', slug: 'electrocasnice-casa' },
  { name: 'Decoratiuni Casa', slug: 'decoratiuni-casa' },
  { name: 'Curatenie si Intretinere', slug: 'curatenie-intretinere' }
];

const legalLinks = [
  { name: 'Politica de Confidentialitate', slug: 'privacy-policy' },
  { name: 'Termeni si Conditii', slug: 'terms' },
  { name: 'Politica Cookies', slug: 'cookies' }
];
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <div class="footer-brand">
          <img src="/logo-white.png" alt="CentroCasa" class="footer-logo-img" width="571" height="120">
        </div>
        <p class="footer-desc">
          Sfaturi practice si recomandari de produse pentru casa si gradina ta.
          Te ajutam sa alegi cele mai bune solutii pentru nevoile tale.
        </p>
      </div>

      <div>
        <h4 class="footer-title">Categorii</h4>
        <ul class="footer-links">
          {categories.map(cat => (
            <li><a href={`/${cat.slug}/`}>{cat.name}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="footer-title">Legal</h4>
        <ul class="footer-links">
          {legalLinks.map(link => (
            <li><a href={`/${link.slug}/`}>{link.name}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="footer-title">Link-uri Utile</h4>
        <ul class="footer-links">
          <li><a href="/">Acasa</a></li>
          <li><a href="/autori/">Autori</a></li>
          <li><a href="/contact/">Contact</a></li>
          <li><a href="/sitemap/">Sitemap</a></li>
          <li><a href="https://ofertatelefoane.ro/">Top Telefoane</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {currentYear} CentroCasa.ro - Toate drepturile rezervate.</p>
    </div>
  </div>
</footer>
